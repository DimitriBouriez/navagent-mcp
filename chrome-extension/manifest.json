{
  "manifest_version": 3,
  "name": "NavAgent",
  "version": "0.1.0",
  "description": "Let your AI assistant (Claude, Cursor, etc.) browse the web using your real Chrome session.",
  "author": "dimitri.bouriez.dev@gmail.com",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "scripting", "alarms", "storage"],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["shadow-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lib.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
